' -----------------------------------------------------------------------------
' CHAPITRE 3 — Séquence : S'inscrire
' -----------------------------------------------------------------------------
@startuml seq-inscription
!theme plain
title Séquence — S'inscrire

actor Utilisateur as U
participant "React" as R
participant "Express API" as API
database "MongoDB" as DB

U -> R : Remplit formulaire
R -> API : POST /api/auth/register
API -> API : Valider + hashPassword()
API -> DB : User.create()
DB --> API : document user
API -> API : Générer JWT + refresh token
API --> R : 201 { accessToken, refreshToken, user }
R --> U : Redirection accueil

@enduml


' -----------------------------------------------------------------------------
' CHAPITRE 3 — Séquence : Se connecter
' -----------------------------------------------------------------------------
@startuml seq-connexion
!theme plain
title Séquence — Se connecter

actor Utilisateur as U
participant "React" as R
participant "Express API" as API
database "MongoDB" as DB

U -> R : Email + mot de passe
R -> API : POST /api/auth/login
API -> DB : User.findOne({ email })
DB --> API : user

alt Mot de passe invalide
  API --> R : 401 Unauthorized
  R --> U : Message erreur
else Mot de passe valide
  API -> API : comparePassword()\nsignAccessToken()\ncreateRefreshToken()
  API -> DB : Sauvegarder refresh token
  API --> R : 200 { accessToken, refreshToken }
  R -> R : Stocker tokens
  R --> U : Accès plateforme
end

@enduml


