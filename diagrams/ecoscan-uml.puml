A --> UC4
S --> UC1
S --> UC3
S --> UC5

UC2 ..> UC1 : <<include>>
UC4 ..> UC3 : <<include>>
UC5 ..> UC4 : <<extend>>

@enduml


' -----------------------------------------------------------------------------
' CHAPITRE 7 — Classes Sprint 5 (Sécurité)
