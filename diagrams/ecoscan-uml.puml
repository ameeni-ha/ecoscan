' -----------------------------------------------------------------------------
' CHAPITRE 2 — Diagramme de classes GLOBAL (corrigé)
' -----------------------------------------------------------------------------
@startuml classe-global
!theme plain
skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam linetype ortho
title Diagramme de classes global — EcoScan Recycle

class User {
  +_id : ObjectId
  +firstName : String
  +lastName : String
  +email : String
  +passwordHash : String
  +role : String
  +accountType : String
  +phone : String
  +address : String
  +points : Number
  +createdAt : Date
  +updatedAt : Date
  --
  +comparePassword(password) : Boolean
  +{static} hashPassword(password) : String
}

class RefreshToken <<embedded>> {
  +tokenIdHash : String
  +expiresAt : Date
  +revokedAt : Date
  +replacedByTokenIdHash : String
}

class Admin {
  +_id : ObjectId
  +firstName : String
  +lastName : String
  +email : String
  +passwordHash : String
  +role : String
  +permissions : String[]
  +adminLevel : String
  +approvalDate : Date
  +approvedBy : ObjectId
  --
  +comparePassword(password) : Boolean
  +hasPermission(permission) : Boolean
  +approveUser(userId, status) : Object
  +removeContent(contentId, type) : Object
  +generateReport(type, range) : Object
}

class City {
  +_id : ObjectId
  +cityName : String
  +governorate : String
  +country : String
  +postalCode : String
  +latitude : Number
  +longitude : Number
  +population : Number
  +isActive : Boolean
  +createdAt : Date
  +updatedAt : Date
  --
  +getCenters() : RecyclingCenter[]
  +getCentersCount() : Number
}

class RecyclingCenter {
  +_id : ObjectId
  +cityId : ObjectId
  +centerName : String
  +managerName : String
  +registrationNumber : String
  +centerType : String
  +materialsAccepted : String[]
  +address : String
  +openingHours : String
  +latitude : Number
  +longitude : Number
  +capacityPerDayKg : Number
  +currentCapacityKg : Number
  +isVerified : Boolean
  +rating : Number
  --
  +getAvailableCapacity() : Number
  +canAcceptMaterial(material) : Boolean
  +updateOperatingHours(hours) : Boolean
}

class Scan {
  +_id : ObjectId
  +userId : ObjectId
  +label : String
  +material : String
  +recyclable : Boolean
  +instructions : String
  +points : Number
  +photoUrl : String
  +createdAt : Date
  +updatedAt : Date
}

class PointsHistory {
  +_id : ObjectId
  +userId : ObjectId
  +scanId : ObjectId
  +material : String
  +pointsEarned : Number
  +reason : String
  +description : String
  +status : String
  +metadata : Object
  +createdAt : Date
}

class Post {
  +_id : ObjectId
  +authorId : ObjectId
  +title : String
  +content : String
  +tags : String[]
  +status : String
  +images : Image[]
  +createdAt : Date
  +updatedAt : Date
}

class Comment {
  +_id : ObjectId
  +postId : ObjectId
  +authorId : ObjectId
  +content : String
  +parentCommentId : ObjectId
  +status : String
  +createdAt : Date
}

class MeetingRequest {
  +_id : ObjectId
  +requesterId : ObjectId
  +centerUserId : ObjectId
  +preferredDate : Date
  +message : String
  +status : String
  +material : String
  +scanId : ObjectId
  +acceptedAt : Date
  +rejectedAt : Date
  +meetingConfirmedDate : Date
}

class Notification {
  +_id : ObjectId
  +userId : ObjectId
  +type : String
  +title : String
  +message : String
  +relatedId : ObjectId
  +relatedModel : String
  +data : Object
  +isRead : Boolean
  +readAt : Date
  +expiresAt : Date
}

User "1" *-- "0..*" RefreshToken : refreshTokens
User "1" --> "0..*" Scan : effectue
User "1" --> "0..*" Post : publie
User "1" --> "0..*" Comment : rédige
User "1" --> "0..*" MeetingRequest : demande
User "1" --> "0..*" Notification : reçoit
User "1" --> "0..*" PointsHistory : accumule

Scan "0..1" --> "0..1" PointsHistory : génère
Scan "0..1" ..> "0..*" MeetingRequest : référence

Post "1" --> "0..*" Comment : contient
Comment "0..1" --> "0..*" Comment : réponses

City "1" --> "0..*" RecyclingCenter : contient
RecyclingCenter "1" --> "0..*" MeetingRequest : reçoit

Admin "0..1" --> "0..*" Admin : approuve

note bottom of Admin
  Pas d'héritage User → Admin.
  Collections MongoDB séparées.
end note

note bottom of City
  Une ville regroupe plusieurs
  centres de recyclage.
end note

@enduml


