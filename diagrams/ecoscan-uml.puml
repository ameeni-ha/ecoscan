' -----------------------------------------------------------------------------
' CHAPITRE 4 — Activité : Scanner un objet
' -----------------------------------------------------------------------------
@startuml activite-scanner
!theme plain
title Activité — Scanner un objet

start
:Ouvrir interface scan;

if (Caméra ou upload ?) then (Caméra)
  :Activer getUserMedia;
  :Capturer image;
else (Upload)
  :Sélectionner fichier;
endif

:Charger modèle TensorFlow.js;
:Détecter objets (COCO-SSD);

if (Confiance > 50% ?) then (oui)
  :Proposer matériau;
else (non)
  :Saisie manuelle matériau;
endif

:Valider label + matériau;
:POST /api/scans + photo;
:Créer Scan + PointsHistory;
:Mettre à jour User.points;
:Afficher résultat et points;

stop

@enduml


