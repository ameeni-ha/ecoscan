' -----------------------------------------------------------------------------
' CHAPITRE 7 — Séquence : Authentification sécurisée (refresh)
' -----------------------------------------------------------------------------
@startuml seq-auth-securisee
!theme plain
title Séquence — Authentification sécurisée (refresh token)

actor Utilisateur as U
participant "React" as R
participant "Express" as API
participant "TokenManager" as TM
database "MongoDB" as DB

R -> API : Requête + Bearer accessToken

alt Token expiré
  API --> R : 401
  R -> API : POST /api/auth/refresh
  API -> TM : rotateRefreshToken()
  TM -> DB : Vérifier + révoquer ancien
  TM --> API : nouveaux tokens
  API --> R : 200 { accessToken, refreshToken }
  R -> API : Retry requête initiale
  API --> R : 200 données
else Token valide
  API --> R : 200 données
end

U <-- R : Réponse

@enduml


