participant "React +\nLeaflet" as R
participant "Navigateur" as Nav
participant "Express" as API
database "MongoDB" as DB

U -> R : Ouvrir page centres / carte
R -> Nav : navigator.geolocation\n.getCurrentPosition()
Nav --> R : { latitude, longitude }

alt Géolocalisation refusée
  R --> U : Message erreur\n+ saisie manuelle
  U -> R : Saisir coordonnées ou ville
else Position obtenue
  R -> R : Centrer carte sur position
endif

R -> API : GET /api/centers/nearby?lat=X&lng=Y&radius=Z
API -> DB : RecyclingCenter.find()\n+ filtre matériau (optionnel)
DB --> API : liste centres
API -> API : Calcul distance Haversine\n+ tri par proximité
API --> R : 200 { centers, count }
R -> R : Ajouter marqueurs Leaflet\n+ popups détails
R --> U : Carte interactive avec centres

@enduml


