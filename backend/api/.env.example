PORT=4000

# MongoDB installe localement (port par defaut 27017).
MONGO_URI=mongodb://127.0.0.1:27017/ecoscan

# MongoDB Atlas ou autre hebergeur (remplissez vos identifiants) :
# MONGO_URI=mongodb+srv://USER:PASSWORD@votre-cluster.mongodb.net/ecoscan?retryWrites=true&w=majority

# Optionnel — CORS. En dev vous pouvez omettre cette ligne : l'API acceptera
# l'origine du navigateur (utile si React utilise le port 3001 ou autre).
# CLIENT_URL=http://localhost:3000,http://127.0.0.1:3000
